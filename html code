
<!DOCTYPE html>
<html>
<head>
<title>Spotify Now Playing</title>
</head>

<body style="background:black;color:white;font-family:sans-serif;text-align:center;margin-top:40vh;font-size:40px">

<div id="song">Login to Spotify</div>

<script>

const clientId = "3caeb60e0d5a4b44a1db78653383f390";
const redirectUri = "https://github.com/nanachiiiiii/standalone-quest-vrc-chatbox-spotify-display.git";

const hash = window.location.hash;

if(!hash){
  const authUrl =
  "https://accounts.spotify.com/authorize" +
  "?client_id=" + clientId +
  "&response_type=code" +
  "&redirect_uri=" + encodeURIComponent(redirectUri) +
  "&scope=user-read-currently-playing";

  document.getElementById("song").innerHTML =
  "<a style='color:white' href='"+authUrl+"'>Login with Spotify</a>";
}

else{

const token = hash.substring(1).split("&")[0].split("=")[1];

async function updateSong(){

const r = await fetch(
"https://api.spotify.com/v1/me/player/currently-playing",
{ headers:{ Authorization:"Bearer "+token } }
);

if(r.status === 204) return;

const data = await r.json();

const name = data.item.name;
const artist = data.item.artists[0].name;

document.getElementById("song").innerText =
"Now Playing: " + name + " - " + artist;

}

setInterval(updateSong,3000);
updateSong();

}

</script>

</body>
</html>
